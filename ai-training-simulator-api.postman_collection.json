{
  "info": {
    "_postman_id": "ai-training-simulator-api",
    "name": "AI Training Simulator API",
    "description": "Complete API reference for the AI Training Simulator platform.\n\n**Setup:**\n1. Set the `baseUrl` variable to your server (default: `http://localhost:8080/api`)\n2. Auth is handled via Clerk session cookies — after signing in through the web app your browser session will be active. For direct API calls, grab your session token from the browser (DevTools → Application → Cookies → `__session`) and add it as a Cookie header.\n\n**Roles:**\n- 🟣 Owner — platform-wide access (domingo.jesse@gmail.com)\n- 🔵 Admin — org-level module/user management\n- 🟢 Learner — can only see assigned modules and own attempts",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api", "type": "string" },
    { "key": "orgId",   "value": "1",  "type": "string" },
    { "key": "moduleId","value": "1",  "type": "string" },
    { "key": "userId",  "value": "",   "type": "string" },
    { "key": "attemptId","value": "1", "type": "string" },
    { "key": "groupId", "value": "1",  "type": "string" },
    { "key": "questionId","value":"1", "type": "string" }
  ],
  "item": [

    {
      "name": "🏥 Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Returns `{ status: 'ok' }`. No auth required."
          }
        },
        {
          "name": "Health check (legacy)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/healthz", "host": ["{{baseUrl}}"], "path": ["healthz"] },
            "description": "Legacy alias for /health."
          }
        }
      ]
    },

    {
      "name": "👤 Users",
      "item": [
        {
          "name": "Get current user",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users","me"] },
            "description": "Returns the authenticated user's profile, org membership, and role."
          }
        },
        {
          "name": "Sync Clerk user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"name\": \"Jane Smith\",\n  \"authProvider\": \"clerk\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/sync", "host": ["{{baseUrl}}"], "path": ["users","sync"] },
            "description": "Called automatically on first login. Provisions a Clerk user into the local DB."
          }
        },
        {
          "name": "Update current user",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"username\": \"janesmith\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users","me"] },
            "description": "Update display name or username for the current user."
          }
        }
      ]
    },

    {
      "name": "🏢 Organizations",
      "item": [
        {
          "name": "List my organizations",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/organizations", "host": ["{{baseUrl}}"], "path": ["organizations"] },
            "description": "Returns all org memberships for the current user."
          }
        },
        {
          "name": "List org members",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/organizations/{{orgId}}/members?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["organizations","{{orgId}}","members"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            },
            "description": "🔵 Admin. Lists all members in the org with pagination."
          }
        },
        {
          "name": "Add member to org",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"learner@company.com\",\n  \"role\": \"learner\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/organizations/{{orgId}}/members", "host": ["{{baseUrl}}"], "path": ["organizations","{{orgId}}","members"] },
            "description": "🔵 Admin. Adds an existing user to the org. Role: 'admin' | 'learner'."
          }
        },
        {
          "name": "Update member role",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/organizations/{{orgId}}/members/{{userId}}", "host": ["{{baseUrl}}"], "path": ["organizations","{{orgId}}","members","{{userId}}"] },
            "description": "🔵 Admin. Changes a member's role."
          }
        },
        {
          "name": "Remove member from org",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/organizations/{{orgId}}/members/{{userId}}", "host": ["{{baseUrl}}"], "path": ["organizations","{{orgId}}","members","{{userId}}"] },
            "description": "🔵 Admin. Deactivates (soft-deletes) a member."
          }
        }
      ]
    },

    {
      "name": "📚 Modules",
      "item": [
        {
          "name": "List modules",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/modules?orgId={{orgId}}",
              "host": ["{{baseUrl}}"],
              "path": ["modules"],
              "query": [{ "key": "orgId", "value": "{{orgId}}" }]
            },
            "description": "🔵 Admin. Lists all training modules for an organization."
          }
        },
        {
          "name": "Get module + questions",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/modules/{{moduleId}}", "host": ["{{baseUrl}}"], "path": ["modules","{{moduleId}}"] },
            "description": "Returns module details including all questions and their config."
          }
        },
        {
          "name": "Create module",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orgId\": {{orgId}},\n  \"title\": \"Handling Difficult Customers\",\n  \"category\": \"Customer Service\",\n  \"difficulty\": \"intermediate\",\n  \"description\": \"Practice de-escalating frustrated customers.\",\n  \"estimatedTime\": \"20 minutes\",\n  \"learningObjectives\": \"Identify escalation triggers. Apply de-escalation techniques. Maintain composure under pressure.\",\n  \"scenarioTicket\": \"Customer called in furious about a 3-week delayed order.\",\n  \"scenarioContext\": \"It's a Monday morning. You receive a call from Maria, who ordered a birthday gift for her daughter 3 weeks ago...\",\n  \"hiddenRootCause\": \"Warehouse software glitch caused the order to be stuck in processing.\",\n  \"expectedDiagnosis\": \"Acknowledge the delay, apologize sincerely, escalate to priority shipping.\",\n  \"expectedReasoningPath\": \"Empathize → Investigate → Resolve → Follow up\",\n  \"expectedNextSteps\": \"Offer refund or priority re-ship. Log the warehouse issue.\",\n  \"lessonTakeaway\": \"Angry customers want to feel heard before they want solutions.\",\n  \"llmScoringEnabled\": true,\n  \"llmGraderInstructions\": \"Score based on empathy, clarity, and whether the learner offered a resolution.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/modules", "host": ["{{baseUrl}}"], "path": ["modules"] },
            "description": "🔵 Admin. Creates a new training module. Questions are added separately."
          }
        },
        {
          "name": "Update module",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Handling Difficult Customers v2\",\n  \"difficulty\": \"advanced\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/modules/{{moduleId}}", "host": ["{{baseUrl}}"], "path": ["modules","{{moduleId}}"] },
            "description": "🔵 Admin. Partial update — only include fields you want to change."
          }
        },
        {
          "name": "Delete module",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/modules/{{moduleId}}", "host": ["{{baseUrl}}"], "path": ["modules","{{moduleId}}"] },
            "description": "🔵 Admin. Deletes module and all its questions."
          }
        },
        {
          "name": "Add question to module",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questionText\": \"How would you open this call to immediately put Maria at ease?\",\n  \"expectedAnswer\": \"Apologise immediately, use her name, acknowledge the inconvenience.\",\n  \"maxPoints\": 15,\n  \"questionType\": \"open_text\",\n  \"rubric\": \"Award full marks for empathy + acknowledgement. Deduct for defensiveness.\",\n  \"questionOrder\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/modules/{{moduleId}}/questions", "host": ["{{baseUrl}}"], "path": ["modules","{{moduleId}}","questions"] },
            "description": "🔵 Admin. Adds a question. questionType: 'open_text' | 'ai_conversation'.\n\nFor ai_conversation, also include:\n- aiRoleOrPersona: 'Angry Customer — Maria'\n- aiConversationPrompt: full character brief (personality, traits, lines)\n- evaluationFocus: what the grader should look for"
          }
        },
        {
          "name": "Add AI conversation question",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questionText\": \"Speak directly with Maria and resolve her complaint.\",\n  \"expectedAnswer\": \"Learner should apologise, investigate, offer refund or priority re-ship.\",\n  \"maxPoints\": 20,\n  \"questionType\": \"ai_conversation\",\n  \"rubric\": \"Score on empathy, resolution quality, and professionalism under pressure.\",\n  \"questionOrder\": 2,\n  \"aiRoleOrPersona\": \"Angry Customer — Maria\",\n  \"aiConversationPrompt\": \"You are Maria, a mother who ordered a birthday gift for her daughter 3 weeks ago and it never arrived. You are furious — this ruined your daughter's birthday. You are not immediately mollified by apologies; you want concrete action. If the agent is dismissive or reads from a script, you escalate. If they genuinely empathise and offer something real (refund, priority shipping, manager), you soften slightly but remain curt. You speak in short, sharp sentences. You interrupt. You say things like 'I've heard that before' and 'That's not good enough.'\",\n  \"evaluationFocus\": \"Does the learner de-escalate effectively? Do they offer a real resolution? Do they stay calm?\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/modules/{{moduleId}}/questions", "host": ["{{baseUrl}}"], "path": ["modules","{{moduleId}}","questions"] },
            "description": "🔵 Admin. AI roleplay question — the learner speaks live with the AI character."
          }
        },
        {
          "name": "Update question",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"maxPoints\": 20,\n  \"rubric\": \"Updated rubric here.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/modules/{{moduleId}}/questions/{{questionId}}", "host": ["{{baseUrl}}"], "path": ["modules","{{moduleId}}","questions","{{questionId}}"] },
            "description": "🔵 Admin. Partial update on a question."
          }
        },
        {
          "name": "Delete question",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/modules/{{moduleId}}/questions/{{questionId}}", "host": ["{{baseUrl}}"], "path": ["modules","{{moduleId}}","questions","{{questionId}}"] },
            "description": "🔵 Admin."
          }
        },
        {
          "name": "AI — Quick generate module",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Sales objection handling for enterprise SaaS — prospects who say the price is too high\",\n  \"difficulty\": \"intermediate\",\n  \"questionCount\": 5,\n  \"orgId\": {{orgId}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/modules/generate", "host": ["{{baseUrl}}"], "path": ["modules","generate"] },
            "description": "🔵 Admin. One-shot AI generation. Returns a complete module draft (not saved — admin reviews and saves manually)."
          }
        },
        {
          "name": "AI — Nova planning chat",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messages\": [\n    { \"role\": \"user\", \"content\": \"I want to build a module for handling irate customers\" }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/modules/plan-chat", "host": ["{{baseUrl}}"], "path": ["modules","plan-chat"] },
            "description": "🔵 Admin. Conversational module planning with Nova (GPT-4o). Pass the full message history each turn.\n\nResponse: { done: false, message: string } or { done: true, message: string, module: {...} }\n\nWhen done=true, the module object contains the complete generated module draft."
          }
        }
      ]
    },

    {
      "name": "📋 Assignments",
      "item": [
        {
          "name": "Get my assignments (learner)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/assignments/my", "host": ["{{baseUrl}}"], "path": ["assignments","my"] },
            "description": "🟢 Learner. Returns all active module assignments for the current user."
          }
        },
        {
          "name": "List org assignments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/assignments?orgId={{orgId}}",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"],
              "query": [{ "key": "orgId", "value": "{{orgId}}" }]
            },
            "description": "🔵 Admin. All assignments in the org."
          }
        },
        {
