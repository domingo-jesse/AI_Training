            },
            "url": { "raw": "{{baseUrl}}/assignments", "host": ["{{baseUrl}}"], "path": ["assignments"] },
            "description": "🔵 Admin. Assigns a module to a specific learner with an optional due date."
          }
        },
        {
          "name": "Remove assignment",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/assignments/1", "host": ["{{baseUrl}}"], "path": ["assignments","1"] },
            "description": "🔵 Admin. Soft-deletes an assignment."
          }
        }
      ]
    },

    {
      "name": "🎯 Attempts",
      "item": [
        {
          "name": "Start attempt",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"moduleId\": {{moduleId}},\n  \"orgId\": {{orgId}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/attempts", "host": ["{{baseUrl}}"], "path": ["attempts"] },
            "description": "🟢 Learner. Creates a new attempt record. Returns attemptId for subsequent saves."
          }
        },
        {
          "name": "Get my attempts",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/attempts/my", "host": ["{{baseUrl}}"], "path": ["attempts","my"] },
            "description": "🟢 Learner. Lists all the current user's attempts with status and score."
          }
        },
        {
          "name": "List org attempts (admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/attempts?orgId={{orgId}}",
              "host": ["{{baseUrl}}"],
              "path": ["attempts"],
              "query": [{ "key": "orgId", "value": "{{orgId}}" }]
            },
            "description": "🔵 Admin. All attempts across the org."
          }
        },
        {
          "name": "Get attempt details",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/attempts/{{attemptId}}", "host": ["{{baseUrl}}"], "path": ["attempts","{{attemptId}}"] },
            "description": "Returns full attempt with question responses and grading."
          }
        },
        {
          "name": "Auto-save responses",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questionResponses\": [\n    {\n      \"questionId\": 1,\n      \"questionText\": \"How would you open this call?\",\n      \"response\": \"I would start by apologising sincerely and using Maria's name...\"\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/attempts/{{attemptId}}", "host": ["{{baseUrl}}"], "path": ["attempts","{{attemptId}}"] },
            "description": "🟢 Learner. Saves draft responses mid-simulation. Safe to call repeatedly."
          }
        },
        {
          "name": "Submit attempt",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"questionResponses\": [\n    {\n      \"questionId\": 1,\n      \"questionText\": \"How would you open this call?\",\n      \"response\": \"I would apologise immediately, use Maria's name, and acknowledge the impact...\"\n    },\n    {\n      \"questionId\": 2,\n      \"questionText\": \"Speak directly with Maria and resolve her complaint.\",\n      \"response\": \"[Angry Customer — Maria]: Where is my order? This is unacceptable!\\n\\n[You]: Maria, I'm so sorry — I can hear how frustrated you are and that's completely valid. Let me pull up your order right now.\\n\\n[Angry Customer — Maria]: I've been waiting 3 weeks. My daughter's birthday was ruined.\\n\\n[You]: That breaks my heart to hear. Here's what I'm going to do right now: I'm flagging this for priority overnight shipping and processing a full refund simultaneously.\"\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/attempts/{{attemptId}}/submit", "host": ["{{baseUrl}}"], "path": ["attempts","{{attemptId}}","submit"] },
            "description": "🟢 Learner. Final submission. Locks the attempt for grading."
          }
        },
        {
          "name": "Preview AI grading",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": { "raw": "{{baseUrl}}/attempts/{{attemptId}}/grade-ai", "host": ["{{baseUrl}}"], "path": ["attempts","{{attemptId}}","grade-ai"] },
            "description": "🔵 Admin. Runs GPT-4o grading and returns suggestions — does not save. Admin can review before applying."
          }
        },
        {
          "name": "Save manual grade",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grades\": [\n    { \"questionId\": 1, \"score\": 13, \"feedback\": \"Strong empathy, good use of name. Could have mentioned investigating sooner.\" },\n    { \"questionId\": 2, \"score\": 18, \"feedback\": \"Excellent de-escalation. Offered concrete resolution quickly. Stayed calm throughout.\" }\n  ],\n  \"overallFeedback\": \"Strong performance overall. Work on frontloading the investigation step.\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/attempts/{{attemptId}}/grade", "host": ["{{baseUrl}}"], "path": ["attempts","{{attemptId}}","grade"] },
            "description": "🔵 Admin. Records final grades and feedback for each question."
          }
        },
        {
          "name": "Org progress stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/progress/org?orgId={{orgId}}",
              "host": ["{{baseUrl}}"],
              "path": ["progress","org"],
              "query": [{ "key": "orgId", "value": "{{orgId}}" }]
            },
            "description": "🔵 Admin. Aggregate stats: completion rates, avg scores, per-module breakdown."
          }
        }
      ]
    },

